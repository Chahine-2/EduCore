<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.EvaluationController"
            style="-fx-font-family: 'Segoe UI'; -fx-background-color: linear-gradient(to bottom right, #eef2ff, #f8fafc);"
            prefWidth="1440" prefHeight="920">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-padding: 16 18; -fx-background-color: rgba(255,255,255,0.94); -fx-border-color: #dbeafe; -fx-border-width: 0 0 1 0;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Administration / Evaluations" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Label text="Evaluation Management" style="-fx-font-size: 25px; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                    <Label text="Define assessment windows, scoring rules, and manage related questions."
                           wrapText="true" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                </VBox>
                <Button text="Retour Home" onAction="#handleBackHome" minWidth="138"
                        style="-fx-background-color: white; -fx-border-color: #93c5fd; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: 700; -fx-padding: 8 14;"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-padding: 10 18; -fx-background-color: rgba(255,255,255,0.88);">
                <Label text="Filter" style="-fx-font-weight: 700; -fx-text-fill: #334155;"/>
                <TextField fx:id="searchField" promptText="Search by title" prefWidth="250"
                           onKeyReleased="#handleSearchKey"
                           style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10;"/>
                <Button text="Apply" onAction="#handleSearch"
                        style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 10;"/>
                <Button text="Clear" onAction="#handleShowAll"
                        style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Sort" style="-fx-font-weight: 700; -fx-text-fill: #334155;"/>
                <ComboBox fx:id="sortCombo" prefWidth="232"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Page size" style="-fx-font-weight: 700; -fx-text-fill: #334155;"/>
                <ComboBox fx:id="pageSizeCombo" prefWidth="72"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Results" style="-fx-font-weight: 700; -fx-text-fill: #334155;"/>
                <Label fx:id="totalLabel" text="0"
                       style="-fx-background-color: #eff6ff; -fx-text-fill: #1e40af; -fx-padding: 4 10; -fx-background-radius: 999; -fx-font-weight: 700;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.37" style="-fx-padding: 14;">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox spacing="12" maxWidth="Infinity"
                      style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 12; -fx-border-color: #dbeafe; -fx-border-radius: 12; -fx-padding: 14;">
                    <Label text="Evaluation record" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                    <Label text="Required fields for creation. Select a table row to update or delete."
                           wrapText="true" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>

                    <Label text="Content" style="-fx-font-weight: 800; -fx-text-fill: #334155;"/>
                    <VBox spacing="6">
                        <Label text="Title" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                        <TextField fx:id="titreField" promptText="Assessment title"
                                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Description" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                        <TextArea fx:id="descriptionField" prefRowCount="4" promptText="Instructions shown to students"
                                  wrapText="true"
                                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;"/>
                    </VBox>

                    <Label text="Scoring" style="-fx-font-weight: 800; -fx-text-fill: #334155;"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        </columnConstraints>
                        <VBox spacing="6" GridPane.columnIndex="0">
                            <Label text="Duration (minutes)" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                            <TextField fx:id="dureeField" promptText="60"
                                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;"/>
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1">
                            <Label text="Maximum score" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                            <TextField fx:id="noteMaxField" promptText="100"
                                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;"/>
                        </VBox>
                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0">
                            <Label text="Passing grade" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                            <TextField fx:id="notePassageField" promptText="50"
                                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;"/>
                        </VBox>
                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Label text="Created" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 10;">
                                <Label fx:id="dateCreationLabel" text="—" wrapText="true" style="-fx-text-fill: #475569;"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <Label text="Availability" style="-fx-font-weight: 800; -fx-text-fill: #334155;"/>
                    <VBox spacing="10">
                        <Label text="Start" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                        <DatePicker fx:id="dateDebutPicker" maxWidth="Infinity"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Time (24h)" style="-fx-text-fill: #64748b;"/>
                            <Spinner fx:id="debutHourSpinner" editable="true"/>
                            <Label text=":"/>
                            <Spinner fx:id="debutMinuteSpinner" editable="true"/>
                            <Label text=":"/>
                            <Spinner fx:id="debutSecondSpinner" editable="true"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="10">
                        <Label text="End" style="-fx-font-weight: 700; -fx-text-fill: #475569;"/>
                        <DatePicker fx:id="dateFinPicker" maxWidth="Infinity"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Time (24h)" style="-fx-text-fill: #64748b;"/>
                            <Spinner fx:id="finHourSpinner" editable="true"/>
                            <Label text=":"/>
                            <Spinner fx:id="finMinuteSpinner" editable="true"/>
                            <Label text=":"/>
                            <Spinner fx:id="finSecondSpinner" editable="true"/>
                        </HBox>
                    </VBox>

                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS" minWidth="0"/>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS" minWidth="0"/>
                        </columnConstraints>
                        <Button text="Create" onAction="#handleAdd" maxWidth="Infinity"
                                style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 8;"
                                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Button text="Save changes" onAction="#handleUpdate" maxWidth="Infinity"
                                style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 8;"
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Button text="Reset form" onAction="#handleClear" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8;"
                                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Button text="Delete" onAction="#handleDelete" maxWidth="Infinity"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 8;"
                                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>
            </ScrollPane>

            <VBox spacing="10" style="-fx-padding: 0 0 0 14;">
                <VBox spacing="2" style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 12; -fx-border-color: #dbeafe; -fx-border-radius: 12; -fx-padding: 12;">
                    <Label text="Published evaluations" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                    <Label text="Sort and paginate below. Select a row to load it into the form."
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: rgba(255,255,255,0.92); -fx-padding: 10 12; -fx-background-radius: 10; -fx-border-color: #dbeafe; -fx-border-radius: 10;">
                    <Button fx:id="prevPageBtn" text="Previous" onAction="#handlePrevPage"/>
                    <Label fx:id="pageInfoLabel" text="Page 1 / 1" style="-fx-text-fill: #475569; -fx-font-weight: 700;"/>
                    <Button fx:id="nextPageBtn" text="Next" onAction="#handleNextPage"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Select a row to edit fields on the left." style="-fx-text-fill: #64748b;"/>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS"
                           style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 12; -fx-border-color: #dbeafe; -fx-border-radius: 12; -fx-padding: 10;">
                    <TableView fx:id="evaluationTable" style="-fx-background-radius: 8;">
                        <columns>
                            <TableColumn text="Title" prefWidth="148" minWidth="100"/>
                            <TableColumn text="Description" prefWidth="168" minWidth="80"/>
                            <TableColumn text="Duration" prefWidth="72" minWidth="56"/>
                            <TableColumn text="Pass" prefWidth="52" minWidth="44"/>
                            <TableColumn text="Max" prefWidth="48" minWidth="40"/>
                            <TableColumn text="Start" prefWidth="128" minWidth="100"/>
                            <TableColumn text="End" prefWidth="128" minWidth="100"/>
                            <TableColumn text="Created" prefWidth="118" minWidth="90"/>
                            <TableColumn text="Status" prefWidth="92" minWidth="72"/>
                            <TableColumn text="Actions" prefWidth="268" minWidth="240"/>
                        </columns>
                    </TableView>
                    <Label fx:id="emptyLabel"
                           text="No evaluations match the current filter. Clear the filter or create a new evaluation."
                           visible="false" alignment="CENTER" wrapText="true"
                           style="-fx-background-color: rgba(255,255,255,0.96); -fx-padding: 12; -fx-text-fill: #64748b;"
                           StackPane.alignment="CENTER"/>
                </StackPane>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: rgba(255,255,255,0.94); -fx-padding: 10 16; -fx-border-color: #dbeafe; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #0f766e; -fx-font-weight: 600;" HBox.hgrow="ALWAYS"/>
            <Label text="EDUCORE Learning Platform" style="-fx-text-fill: #64748b;"/>
        </HBox>
    </bottom>
</BorderPane>
