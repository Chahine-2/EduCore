<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.GestionMaterielController"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <Label text="Gestion des Materiels"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>

    <GridPane hgap="10" vgap="5">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <!-- Nom -->
        <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1">
            <TextField fx:id="tfNom" prefWidth="250"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errNom" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Code -->
        <Label text="Code :" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1">
            <TextField fx:id="tfCode" prefWidth="250"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errCode" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Description -->
        <Label text="Description :" GridPane.rowIndex="2" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1">
            <TextField fx:id="tfDescription" prefWidth="250"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errDescription" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Quantite -->
        <Label text="Quantite :" GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1">
            <TextField fx:id="tfQuantite" prefWidth="250"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errQuantite" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Etat -->
        <Label text="Etat :" GridPane.rowIndex="4" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="4" GridPane.columnIndex="1">
            <ComboBox fx:id="cbEtat" prefWidth="250"
                      style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errEtat" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Departement -->
        <Label text="Departement :" GridPane.rowIndex="5" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="5" GridPane.columnIndex="1">
            <ComboBox fx:id="cbDepartement" prefWidth="250"
                      style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errDepartement" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Salle -->
        <Label text="Salle :" GridPane.rowIndex="6" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="6" GridPane.columnIndex="1">
            <ComboBox fx:id="cbSalle" prefWidth="250"
                      style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errSalle" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter" onAction="#ajouterMateriel"
                style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Modifier" onAction="#modifierMateriel"
                style="-fx-background-color: #34a853; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Supprimer" onAction="#supprimerMateriel"
                style="-fx-background-color: #d93025; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Actualiser" onAction="#afficherMateriels"
                style="-fx-background-color: #9334e6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Voir sur la carte" onAction="#voirSurCarte"
                style="-fx-background-color: #fa7b17; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 150; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tvMateriels" prefHeight="300" prefWidth="800">
        <columns>
            <TableColumn fx:id="colNom"         text="Nom"         prefWidth="150"/>
            <TableColumn fx:id="colCode"        text="Code"        prefWidth="100"/>
            <TableColumn fx:id="colQuantite"    text="Quantite"    prefWidth="80"/>
            <TableColumn fx:id="colEtat"        text="Etat"        prefWidth="120"/>
            <TableColumn fx:id="colSalle"       text="Salle"       prefWidth="130"/>
            <TableColumn fx:id="colDepartement" text="Departement" prefWidth="130"/>
        </columns>
    </TableView>

</VBox>