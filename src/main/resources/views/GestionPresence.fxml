<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.GestionPresenceController"
            styleClass="gestion-container">

    <top>
        <VBox spacing="15" styleClass="header-section">
            <padding>
                <Insets top="20" left="20" right="20"/>
            </padding>

            <Label text="Gestion de la Présence des Étudiants" styleClass="title-label"/>
            <Label text="Consultez et enregistrez la présence des étudiants par classe" styleClass="subtitle-label"/>

            <HBox spacing="15" styleClass="controls-section">
                <Label text="Sélectionner un cours:" styleClass="label-field"/>
                <ComboBox fx:id="comboBoxCours" prefWidth="250" promptText="Choisir un cours..."/>

                <Label text="Date:" styleClass="label-field"/>
                <DatePicker fx:id="datePickerPresence" prefWidth="150"/>

                <Button fx:id="btnCharger" text="📂 Charger" styleClass="btn-charger"/>
                <Button fx:id="btnSauvegarder" text="💾 Sauvegarder" styleClass="btn-sauvegarder"/>
            </HBox>

            <Label fx:id="labelStatistiques" text="Total: 0 | Présentes: 0 | Absentes: 0 | Taux: 0.0%" styleClass="stats-label"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablePresence" styleClass="table-presence">
            <columns>
                <TableColumn fx:id="colEtudiantId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colNomEtudiant" text="Nom" prefWidth="150"/>
                <TableColumn fx:id="colPrenomEtudiant" text="Prénom" prefWidth="150"/>
                <TableColumn fx:id="colPresent" text="Présent(e)" prefWidth="80" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colNotes" text="Notes" prefWidth="200" editable="true"/>
            </columns>
        </TableView>
    </center>

    <stylesheets>
        <String/>
    </stylesheets>
</BorderPane>

