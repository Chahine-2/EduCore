<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminDashboardController"
            styleClass="teacher-root"
            stylesheets="@../css/teacher-dashboard.css"
            prefHeight="720" prefWidth="1180">

    <left>
        <VBox styleClass="teacher-sidebar" alignment="TOP_CENTER">
            <VBox styleClass="teacher-brand-block">
                <Label text="EduCore" styleClass="teacher-brand-title"/>
                <Label text="Espace administrateur" styleClass="teacher-brand-sub"/>
            </VBox>

            <VBox styleClass="teacher-sidebar-nav" spacing="5">
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#chargerUtilisateurs"
                        styleClass="teacher-nav-button" text="Actualiser la liste">
                    <graphic><Label styleClass="teacher-nav-icon" text="👥"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAjouterEtudiant"
                        styleClass="teacher-nav-button" text="Ajouter étudiant">
                    <graphic><Label styleClass="teacher-nav-icon" text="🎓"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleModifierEmail"
                        styleClass="teacher-nav-button" text="Modifier utilisateur">
                    <graphic><Label styleClass="teacher-nav-icon" text="✏️"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSupprimerUtilisateur"
                        styleClass="teacher-nav-button" text="Supprimer utilisateur">
                    <graphic><Label styleClass="teacher-nav-icon" text="🗑"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSuspendreCompte"
                        styleClass="teacher-nav-button" text="Suspendre / activer">
                    <graphic><Label styleClass="teacher-nav-icon" text="⏸"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleHistorique"
                        styleClass="teacher-nav-button" text="Historique connexions">
                    <graphic><Label styleClass="teacher-nav-icon" text="🕒"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAjouterProf"
                        styleClass="teacher-nav-button" text="Ajouter enseignant">
                    <graphic><Label styleClass="teacher-nav-icon" text="👨‍🏫"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGestionClasses"
                        styleClass="teacher-nav-button" text="Classes">
                    <graphic><Label styleClass="teacher-nav-icon" text="🏫"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGestionMateriel"
                        styleClass="teacher-nav-button" text="Gestion matériel">
                    <graphic><Label styleClass="teacher-nav-icon" text="🛠"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleStatMateriel"
                        styleClass="teacher-nav-button" text="Statistiques matériel">
                    <graphic><Label styleClass="teacher-nav-icon" text="📈"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGestionHackathonSection"
                        styleClass="teacher-nav-button" text="Gestion Hackathon">
                    <graphic><Label styleClass="teacher-nav-icon" text="🎯"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleStatHackathon"
                        styleClass="teacher-nav-button" text="Stat Hackathon">
                    <graphic><Label styleClass="teacher-nav-icon" text="📊"/></graphic>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGestionPresence"
                        styleClass="teacher-nav-button" text="Gestion Présence">
                    <graphic><Label styleClass="teacher-nav-icon" text="✅"/></graphic>
                </Button>
            </VBox>

            <Region styleClass="teacher-sidebar-spacer" VBox.vgrow="ALWAYS"/>

            <VBox styleClass="teacher-sidebar-footer" spacing="0">
                <Region styleClass="teacher-sidebar-footer-line"/>
                <Button fx:id="btnNavLogout" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        onAction="#handleDeconnexion" styleClass="teacher-nav-button teacher-nav-logout" text="Déconnexion">
                    <graphic><Label styleClass="teacher-nav-icon" text=""/></graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="teacher-main-region">
            <center>
                <ScrollPane fitToWidth="true" styleClass="teacher-content-scroll" hbarPolicy="NEVER">
                    <VBox spacing="16" styleClass="teacher-content-body" maxWidth="1.7976931348623157E308">
                        <HBox styleClass="teacher-dashboard-header-embed" alignment="CENTER_LEFT" spacing="20" maxWidth="1.7976931348623157E308">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="lblWelcome" styleClass="teacher-welcome-title" text="Administration"/>
                                <Label fx:id="lblWelcomeSub" styleClass="teacher-welcome-sub"
                                       text="Gérez les comptes, les classes, le matériel et les hackathons depuis un seul espace."/>
                            </VBox>
                            <Label fx:id="lblDateTime" styleClass="teacher-header-datetime" text="—"/>
                            <StackPane>
                                <Circle radius="22" styleClass="teacher-avatar-circle"/>
                                <Label fx:id="lblAvatarInitials" styleClass="teacher-avatar-initials" text="A"/>
                            </StackPane>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="16" maxWidth="1.7976931348623157E308">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Utilisateurs" styleClass="teacher-section-title"/>
                                <Label text="Sélectionnez une ligne pour modifier, suspendre ou supprimer un compte." styleClass="teacher-section-hint" wrapText="true"/>
                            </VBox>
                            <Button mnemonicParsing="false" onAction="#chargerUtilisateurs" text="Actualiser"
                                    styleClass="teacher-primary-btn"/>
                        </HBox>

                        <FlowPane styleClass="teacher-cards-flow" hgap="18" vgap="18">
                            <VBox styleClass="teacher-stat-card" spacing="10" minWidth="220" prefWidth="248" maxWidth="300"
                                  onMouseClicked="#handleStatHackathon">
                                <Region styleClass="teacher-stat-accent, accent-teach-eval"/>
                                <Label styleClass="teacher-stat-icon" text="🎯"/>
                                <Label text="Hackathons enregistrés" styleClass="teacher-stat-label"/>
                                <Label fx:id="lbTotalHackathonsAdmin" styleClass="teacher-stat-value" text="0"/>
                                <Label text="Cliquez pour ouvrir le tableau de bord" styleClass="teacher-stat-foot"/>
                            </VBox>
                            <VBox styleClass="teacher-stat-card" spacing="10" minWidth="220" prefWidth="248" maxWidth="300">
                                <Region styleClass="teacher-stat-accent, accent-teach-courses"/>
                                <Label styleClass="teacher-stat-icon" text="💰"/>
                                <Label text="Prix moyen (hackathons)" styleClass="teacher-stat-label"/>
                                <Label fx:id="lbPrixMoyenHackathonsAdmin" styleClass="teacher-stat-value" text="0.0 DT"/>
                                <Label text="Moyenne calculée sur la base en cours" styleClass="teacher-stat-foot"/>
                            </VBox>
                            <VBox styleClass="teacher-stat-card" spacing="10" minWidth="220" prefWidth="248" maxWidth="300"
                                  onMouseClicked="#handleGestionHackathonSection">
                                <Region styleClass="teacher-stat-accent, accent-teach-students"/>
                                <Label styleClass="teacher-stat-icon" text="⚙"/>
                                <Label text="Gestion Hackathon" styleClass="teacher-stat-label"/>
                                <Label text="Console" styleClass="teacher-stat-value" style="-fx-font-size: 24px;"/>
                                <Label text="Sessions, équipes et paramètres" styleClass="teacher-stat-foot"/>
                            </VBox>
                        </FlowPane>

                        <VBox spacing="12" styleClass="teacher-panel-card" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS" minHeight="360">
                            <Label text="Annuaire des comptes" styleClass="teacher-section-hint"/>
                            <TableView fx:id="tableUtilisateurs" styleClass="teacher-table" minHeight="300" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colId" prefWidth="56" text="ID"/>
                                    <TableColumn fx:id="colNom" prefWidth="120" text="Nom"/>
                                    <TableColumn fx:id="colPrenom" prefWidth="120" text="Prénom"/>
                                    <TableColumn fx:id="colEmail" prefWidth="220" text="Email"/>
                                    <TableColumn fx:id="colRole" prefWidth="110" text="Rôle"/>
                                    <TableColumn fx:id="colStatut" prefWidth="110" text="Statut"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
