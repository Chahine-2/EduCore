<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterEtudiantController">
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <Label text="Nouvel Étudiant" textFill="#2c3e50">
        <font><Font name="System Bold" size="20.0" /></font>
        <VBox.margin><Insets bottom="10.0" /></VBox.margin>
    </Label>

    <TextField fx:id="txtNom" promptText="Nom" />
    <TextField fx:id="txtPrenom" promptText="Prénom" />
    <TextField fx:id="txtAge" promptText="Âge (ex: 20)" />
    <TextField fx:id="txtEmail" promptText="Email" />
    <TextField fx:id="txtTel" promptText="Téléphone" />
    <PasswordField fx:id="txtMdp" promptText="Mot de passe provisoire" />
    <TextField fx:id="txtNumEtud" promptText="Matricule (ex: ETUD-101)" />

    <ComboBox fx:id="comboClasse" prefWidth="200.0" promptText="Sélectionner une classe" />

    <Label fx:id="lblMessage" textFill="RED" visible="false" />

    <Button mnemonicParsing="false" onAction="#handleValider" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Enregistrer l'étudiant">
        <font><Font name="System Bold" size="14.0" /></font>
    </Button>
</VBox>