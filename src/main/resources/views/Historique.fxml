<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="600.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HistoriqueController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Historique des Connexions" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <TableView fx:id="tableHistorique" prefHeight="400.0" prefWidth="560.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" prefWidth="180.0" text="Date et Heure" />
            <TableColumn fx:id="colEmail" prefWidth="240.0" text="Email utilisé" />
            <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
        </columns>
    </TableView>
</VBox>