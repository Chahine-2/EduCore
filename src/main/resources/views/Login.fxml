<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.LoginController"
      styleClass="login-root"
      stylesheets="@../css/login.css">

    <Region HBox.hgrow="ALWAYS" minWidth="12"/>

    <VBox alignment="TOP_CENTER" spacing="16" styleClass="login-card">
        <padding>
            <Insets bottom="8"/>
        </padding>

        <Label text="Bienvenue sur EduCore" styleClass="login-brand"/>

        <Label text="Veuillez vous connecter pour continuer" styleClass="login-sub">
            <VBox.margin>
                <Insets bottom="8"/>
            </VBox.margin>
        </Label>

        <TextField fx:id="emailField" styleClass="login-field" promptText="Adresse e-mail"/>

        <PasswordField fx:id="passwordField" styleClass="login-field" promptText="Mot de passe"/>

        <Label fx:id="errorLabel" styleClass="login-error" visible="false" managed="false" text=" "/>

        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin"
                styleClass="login-primary" text="Se connecter">
            <VBox.margin>
                <Insets top="6"/>
            </VBox.margin>
        </Button>

        <Hyperlink text="Pas encore de compte ? S'inscrire" onAction="#handleAllerInscription" styleClass="login-signup">
            <VBox.margin>
                <Insets top="8"/>
            </VBox.margin>
        </Hyperlink>
    </VBox>

    <Region HBox.hgrow="ALWAYS" minWidth="12"/>
</HBox>
