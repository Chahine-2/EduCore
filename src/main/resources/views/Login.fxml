<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.LoginController"
      styleClass="login-root"
      stylesheets="@../css/login.css">

    <VBox alignment="TOP_LEFT" styleClass="decoration-top-left" HBox.hgrow="ALWAYS">
        <Label text="📝" styleClass="decoration-icon"/>
        <Label text="✏️" styleClass="decoration-icon"/>
    </VBox>

    <VBox alignment="TOP_CENTER" spacing="20" styleClass="login-card">
        <padding>
            <Insets top="20" bottom="24" left="0" right="0"/>
        </padding>

        <!-- Logo/Brand Icon -->
        <VBox alignment="CENTER" styleClass="logo-container">
            <Label text="◆" styleClass="logo-icon"/>
        </VBox>

        <!-- Title -->
        <Label text="EduCore" styleClass="login-brand">
            <VBox.margin>
                <Insets top="8"/>
            </VBox.margin>
        </Label>

        <!-- Subtitle -->
        <Label text="Plateforme de Gestion Éducative" styleClass="login-subtitle">
            <VBox.margin>
                <Insets bottom="4"/>
            </VBox.margin>
        </Label>

        <Label text="Connectez-vous à votre compte" styleClass="login-sub">
            <VBox.margin>
                <Insets bottom="20"/>
            </VBox.margin>
        </Label>

        <!-- Input Fields Container -->
        <VBox spacing="12" styleClass="inputs-container">
            <Label text="Adresse e-mail" styleClass="field-label"/>
            <TextField fx:id="emailField" styleClass="login-field" promptText="exemple@educore.com"/>

            <Label text="Mot de passe" styleClass="field-label">
                <VBox.margin>
                    <Insets top="8"/>
                </VBox.margin>
            </Label>
            <PasswordField fx:id="passwordField" styleClass="login-field" promptText="Entrez votre mot de passe"/>

            <Hyperlink text="Mot de passe oublié ?" styleClass="forgot-password">
                <VBox.margin>
                    <Insets top="4"/>
                </VBox.margin>
            </Hyperlink>
        </VBox>

        <!-- Error Message -->
        <Label fx:id="errorLabel" styleClass="login-error" visible="false" managed="false" text=" ">
            <VBox.margin>
                <Insets top="8"/>
            </VBox.margin>
        </Label>

        <!-- Login Button -->
        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin"
                styleClass="login-primary" text="Se Connecter">
            <VBox.margin>
                <Insets top="16"/>
            </VBox.margin>
        </Button>

        <!-- Signup Link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Pas encore de compte ?"/>
            <Hyperlink text="S'inscrire" onAction="#handleAllerInscription" styleClass="login-signup"/>
            <VBox.margin>
                <Insets top="16"/>
            </VBox.margin>
        </HBox>

        <!-- Footer -->
        <Region VBox.vgrow="ALWAYS"/>
        <VBox alignment="CENTER" spacing="8" styleClass="login-footer">
            <Label text="© 2026 EduCore. Tous droits réservés." styleClass="footer-text"/>
        </VBox>
    </VBox>

    <VBox alignment="BOTTOM_RIGHT" styleClass="decoration-bottom-right" HBox.hgrow="ALWAYS">
        <Label text="🧮" styleClass="decoration-icon"/>
        <Label text="📊" styleClass="decoration-icon"/>
        <Label text="📚" styleClass="decoration-icon"/>
    </VBox>
</HBox>
