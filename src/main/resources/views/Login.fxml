<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Hyperlink?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Bienvenue sur EduCore" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Veuillez vous connecter pour continuer" textFill="#7f8c8d">
        <font>
            <Font size="14.0" />
        </font>
        <VBox.margin>
            <Insets bottom="20.0" />
        </VBox.margin>
    </Label>

    <TextField fx:id="emailField" prefHeight="35.0" prefWidth="250.0" promptText="Adresse Email" />

    <PasswordField fx:id="passwordField" prefHeight="35.0" prefWidth="250.0" promptText="Mot de passe" />

    <Label fx:id="errorLabel" textFill="#e74c3c" visible="false">
        <font>
            <Font name="System Bold" size="12.0" />
        </font>
    </Label>

    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="Se connecter">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>

    <Hyperlink text="Pas encore de compte ? S'inscrire " onAction="#handleAllerInscription" textFill="#2980b9">
        <font>
            <Font size="13.0" />
        </font>
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Hyperlink>


</VBox>
