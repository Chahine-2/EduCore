<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierUtilisateurController">
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <Label fx:id="lblTitre" text="Modifier Utilisateur" textFill="#2c3e50">
        <font><Font name="System Bold" size="20.0" /></font>
        <VBox.margin><Insets bottom="10.0" /></VBox.margin>
    </Label>

    <TextField fx:id="txtNom" promptText="Nom" />
    <TextField fx:id="txtPrenom" promptText="Prénom" />
    <TextField fx:id="txtAge" promptText="Âge" />
    <TextField fx:id="txtEmail" promptText="Email" />
    <TextField fx:id="txtTel" promptText="Téléphone" />

    <VBox fx:id="boxEtudiant" spacing="12.0" managed="false" visible="false">
        <TextField fx:id="txtNumEtud" promptText="Numéro Étudiant" />
        <TextField fx:id="txtClasse" promptText="Classe (ex: GL-3)" />
    </VBox>

    <VBox fx:id="boxProf" spacing="12.0" managed="false" visible="false">
        <TextField fx:id="txtSpecialite" promptText="Spécialité" />
        <TextField fx:id="txtMatriculeProf" promptText="Matricule Prof" />
    </VBox>

    <Label fx:id="lblMessage" textFill="RED" visible="false" />

    <Button mnemonicParsing="false" onAction="#handleValiderModif" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Sauvegarder">
        <font><Font name="System Bold" size="14.0" /></font>
        <VBox.margin><Insets top="10.0" /></VBox.margin>
    </Button>
</VBox>