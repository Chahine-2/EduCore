<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EnseignantDashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #2980b9;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <children>
                <Label text="ESPACE PROF" textFill="WHITE">
                    <font><Font name="System Bold" size="22.0" /></font>
                    <VBox.margin><Insets bottom="30.0" /></VBox.margin>
                </Label>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="📋 Faire l'appel" />

                <VBox VBox.vgrow="ALWAYS" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeconnexion" prefHeight="40.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="🚪 Déconnexion" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label text="Faire l'appel du jour" textFill="#2c3e50">
                    <font><Font name="System Bold" size="26.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Choisissez une classe :">
                        <font><Font size="14.0" /></font>
                    </Label>
                    <ComboBox fx:id="comboClasse" prefWidth="200.0" promptText="Sélectionner..." />
                    <Button mnemonicParsing="false" onAction="#chargerEtudiants" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="🔍 Afficher les étudiants" />
                </HBox>

                <TableView fx:id="tableEtudiants" prefHeight="350.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMatricule" prefWidth="120.0" text="Matricule" />
                        <TableColumn fx:id="colNom" prefWidth="150.0" text="Nom" />
                        <TableColumn fx:id="colPrenom" prefWidth="150.0" text="Prénom" />
                        <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="20.0">
                    <Button mnemonicParsing="false" onAction="#marquerPresent" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="✅ PRÉSENT" />
                    <Button mnemonicParsing="false" onAction="#marquerAbsent" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="❌ ABSENT" />
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
