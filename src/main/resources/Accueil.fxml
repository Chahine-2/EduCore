<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AccueilController"
            maxWidth="1.7976931348623157E308"
            minWidth="0.0">

    <!-- HAUT (masqué quand intégré au tableau de bord « Mes cours ») -->
    <top>
        <VBox fx:id="accueilTopChrome" style="-fx-background-color: #1a5276; -fx-padding: 20;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🎓 Bienvenue sur EduCore"
                       style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRetourAccueil" text="← Retour"
                        onAction="#retourStartup"
                        style="-fx-background-color: #d6eaf8; -fx-text-fill: #1a5276; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            </HBox>
            <Label text="Choisissez votre catégorie et votre niveau pour commencer"
                   style="-fx-text-fill: #aed6f1; -fx-font-size: 14;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="40"
              alignment="CENTER"
              maxWidth="1.7976931348623157E308"
              minWidth="0.0"
              style="-fx-padding: 60; -fx-background-color: #f4f6f7;">

            <Label text="📋 Sélectionnez vos préférences"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <VBox spacing="10" alignment="CENTER">
                <Label text="🏷️ Catégorie :"
                       style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <HBox spacing="20" alignment="CENTER">
                    <ToggleButton fx:id="tbInfo"
                                  text="💻 Informatique"
                                  onAction="#selectionnerCategorie"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                    <ToggleButton fx:id="tbMeca"
                                  text="⚙️ Mécanique"
                                  onAction="#selectionnerCategorie"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                    <ToggleButton fx:id="tbElec"
                                  text="⚡ Électrique"
                                  onAction="#selectionnerCategorie"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                </HBox>
            </VBox>

            <VBox spacing="10" alignment="CENTER">
                <Label text="📊 Niveau :"
                       style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <HBox spacing="20" alignment="CENTER">
                    <ToggleButton fx:id="tbDebutant"
                                  text="🟢 Débutant"
                                  onAction="#selectionnerNiveau"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                    <ToggleButton fx:id="tbIntermediaire"
                                  text="🟡 Intermédiaire"
                                  onAction="#selectionnerNiveau"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                    <ToggleButton fx:id="tbAvance"
                                  text="🔴 Avancé"
                                  onAction="#selectionnerNiveau"
                                  style="-fx-font-size: 14; -fx-padding: 15 30; -fx-background-radius: 10;"/>
                </HBox>
            </VBox>

            <VBox spacing="5" alignment="CENTER"
                  style="-fx-background-color: #eaf4fb; -fx-padding: 15; -fx-background-radius: 10;">
                <Label fx:id="lblSelection"
                       text="Aucune sélection"
                       style="-fx-font-size: 14; -fx-text-fill: #1a5276;"/>
            </VBox>

            <HBox spacing="14" alignment="CENTER">
                <Button fx:id="btnContinuer"
                        text="▶ Voir mes cours"
                        onAction="#continuer"
                        disable="true"
                        style="-fx-background-color: #1a5276; -fx-text-fill: white;
                               -fx-font-size: 16; -fx-padding: 15 40;
                               -fx-background-radius: 10; -fx-font-weight: bold;"/>
                <Button fx:id="btnEspaceEnseignant" text="👨‍🏫 Espace Enseignant"
                        onAction="#ouvrirEspaceEnseignant"
                        style="-fx-background-color: white; -fx-text-fill: #1a5276;
                               -fx-font-size: 16; -fx-padding: 15 34;
                               -fx-border-color: #1a5276; -fx-border-radius: 10;
                               -fx-background-radius: 10; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox fx:id="accueilFooterBar" style="-fx-background-color: #d6eaf8; -fx-padding: 10;">
            <Label text="EduCore — Plateforme d'apprentissage"
                   style="-fx-text-fill: #1a5276;"/>
        </HBox>
    </bottom>
</BorderPane>
