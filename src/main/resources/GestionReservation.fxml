<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.GestionReservationController"
      style="-fx-padding: 20; -fx-background-color: #f4f6f9;">

    <Label text="Gestion des Reservations"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane hgap="10" vgap="10">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>



        <Label text="Motif :"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="tfMotif"    GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Date debut (yyyy-MM-ddTHH:mm) :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="tfDateDebut" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Date fin (yyyy-MM-ddTHH:mm) :"   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="tfDateFin"  GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Statut :"        GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbStatut"    GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter"    onAction="#ajouterReservation"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;"/>
        <Button text="Modifier"   onAction="#modifierReservation"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;"/>
        <Button text="Supprimer"  onAction="#supprimerReservation"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;"/>
        <Button text="Actualiser" onAction="#afficherReservations"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;"/>
    </HBox>

    <TableView fx:id="tvReservations" prefHeight="350" prefWidth="800">
        <columns>

            <TableColumn fx:id="colMotif"       text="Motif"       prefWidth="150"/>
            <TableColumn fx:id="colDateDebut"   text="Date debut"  prefWidth="150"/>
            <TableColumn fx:id="colDateFin"     text="Date fin"    prefWidth="150"/>
            <TableColumn fx:id="colStatut"      text="Statut"      prefWidth="100"/>
        </columns>
    </TableView>

</VBox>