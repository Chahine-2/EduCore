<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1000.0"
            style="-fx-background-color: #f4f6f9;"
            xmlns="http://javafx.com/javafx/22.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.GestionReservationController">
    <children>

        <!-- HEADER -->
        <AnchorPane layoutX="0.0" layoutY="0.0" prefWidth="1000.0" prefHeight="64.0"
                    style="-fx-background-color: #1a73e8;">
            <children>
                <Label layoutX="30.0" layoutY="16.0"
                       text="🎓  Site Éducatif — Gestion des Réservations"
                       style="-fx-text-fill: white;">
                    <font><Font name="Arial Bold" size="20.0"/></font>
                </Label>
                <Button layoutX="800.0" layoutY="14.0"
                        text="📊  Dashboard"
                        prefWidth="150.0" prefHeight="34.0"
                        onAction="#allerDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.5); -fx-border-radius: 6;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
            </children>
        </AnchorPane>

        <!-- CARTE FORMULAIRE -->
        <AnchorPane layoutX="30.0" layoutY="84.0" prefWidth="460.0" prefHeight="310.0"
                    style="-fx-background-color: white; -fx-background-radius: 10;
                           -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.10),8,0,0,2);">
            <children>
                <Label layoutX="20.0" layoutY="14.0" text="Nouvelle réservation"
                       style="-fx-text-fill: #1a73e8;">
                    <font><Font name="Arial Bold" size="13.0"/></font>
                </Label>
                <Separator layoutX="0.0" layoutY="38.0" prefWidth="460.0"/>

                <Label layoutX="20.0" layoutY="54.0"  text="Titre :"><font><Font name="Arial Bold" size="12.0"/></font></Label>
                <Label layoutX="20.0" layoutY="100.0" text="Description :"><font><Font name="Arial Bold" size="12.0"/></font></Label>
                <Label layoutX="20.0" layoutY="146.0" text="Date début :"><font><Font name="Arial Bold" size="12.0"/></font></Label>
                <Label layoutX="20.0" layoutY="192.0" text="Date fin :"><font><Font name="Arial Bold" size="12.0"/></font></Label>
                <Label layoutX="20.0" layoutY="238.0" text="Nb places :"><font><Font name="Arial Bold" size="12.0"/></font></Label>

                <TextField fx:id="tfTitre" layoutX="140.0" layoutY="50.0" prefWidth="300.0" prefHeight="32.0"
                           promptText="ex : Atelier Java"
                           style="-fx-background-radius: 6; -fx-border-color: #dde1e7; -fx-border-radius: 6;"/>
                <TextField fx:id="tfDescription" layoutX="140.0" layoutY="96.0" prefWidth="300.0" prefHeight="32.0"
                           promptText="ex : Formation avancée"
                           style="-fx-background-radius: 6; -fx-border-color: #dde1e7; -fx-border-radius: 6;"/>
                <DatePicker fx:id="dpDateDebut" layoutX="140.0" layoutY="142.0" prefWidth="300.0" prefHeight="32.0"/>
                <DatePicker fx:id="dpDateFin"   layoutX="140.0" layoutY="188.0" prefWidth="300.0" prefHeight="32.0"/>
                <TextField fx:id="tfNbPlaces" layoutX="140.0" layoutY="234.0" prefWidth="300.0" prefHeight="32.0"
                           promptText="ex : 30"
                           style="-fx-background-radius: 6; -fx-border-color: #dde1e7; -fx-border-radius: 6;"/>

                <Button layoutX="20.0"  layoutY="274.0" text="✚  Ajouter"   prefWidth="120.0" prefHeight="34.0"
                        onAction="#ajouterReservation"
                        style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button layoutX="150.0" layoutY="274.0" text="✎  Modifier"  prefWidth="120.0" prefHeight="34.0"
                        onAction="#modifierReservation"
                        style="-fx-background-color: #f9ab00; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button layoutX="280.0" layoutY="274.0" text="✖  Supprimer" prefWidth="140.0" prefHeight="34.0"
                        onAction="#supprimerReservation"
                        style="-fx-background-color: #d93025; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
            </children>
        </AnchorPane>

        <!-- CARTE INFOS DROITE -->
        <AnchorPane layoutX="510.0" layoutY="84.0" prefWidth="460.0" prefHeight="310.0"
                    style="-fx-background-color: white; -fx-background-radius: 10;
                           -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.10),8,0,0,2);">
            <children>
                <Label layoutX="20.0" layoutY="14.0" text="ℹ  Instructions"
                       style="-fx-text-fill: #1a73e8;">
                    <font><Font name="Arial Bold" size="13.0"/></font>
                </Label>
                <Separator layoutX="0.0" layoutY="38.0" prefWidth="460.0"/>

                <Label layoutX="20.0" layoutY="58.0"
                       text="• Remplissez le formulaire et cliquez Ajouter"
                       style="-fx-text-fill: #5f6368;">
                    <font><Font name="Arial" size="12.0"/></font>
                </Label>
                <Label layoutX="20.0" layoutY="88.0"
                       text="• Cliquez sur une ligne pour la sélectionner"
                       style="-fx-text-fill: #5f6368;">
                    <font><Font name="Arial" size="12.0"/></font>
                </Label>
                <Label layoutX="20.0" layoutY="118.0"
                       text="• Modifiez les champs puis cliquez Modifier"
                       style="-fx-text-fill: #5f6368;">
                    <font><Font name="Arial" size="12.0"/></font>
                </Label>
                <Label layoutX="20.0" layoutY="148.0"
                       text="• Supprimer efface la réservation sélectionnée"
                       style="-fx-text-fill: #5f6368;">
                    <font><Font name="Arial" size="12.0"/></font>
                </Label>

                <Separator layoutX="20.0" layoutY="180.0" prefWidth="420.0"/>

                <Label layoutX="20.0" layoutY="196.0"
                       text="📌  Champs obligatoires : Titre, Dates, Places"
                       style="-fx-text-fill: #d93025;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Label>
                <Label layoutX="20.0" layoutY="226.0"
                       text="📅  La date de fin doit être après la date de début"
                       style="-fx-text-fill: #d93025;">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Label>
            </children>
        </AnchorPane>

        <!-- MESSAGE -->
        <Label fx:id="lbMessage" layoutX="40.0" layoutY="404.0" prefWidth="460.0">
            <font><Font name="Arial Italic" size="12.0"/></font>
        </Label>

        <!-- CARTE TABLEAU -->
        <AnchorPane layoutX="30.0" layoutY="420.0" prefWidth="940.0" prefHeight="240.0"
                    style="-fx-background-color: white; -fx-background-radius: 10;
                           -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.10),8,0,0,2);">
            <children>
                <Label layoutX="20.0" layoutY="12.0" text="Liste des Réservations"
                       style="-fx-text-fill: #1a73e8;">
                    <font><Font name="Arial Bold" size="13.0"/></font>
                </Label>
                <Separator layoutX="0.0" layoutY="36.0" prefWidth="940.0"/>
                <TableView fx:id="tableReservation" layoutX="10.0" layoutY="44.0"
                           prefHeight="186.0" prefWidth="920.0" onMouseClicked="#selectionnerLigne">
                    <columns>
                        <TableColumn fx:id="colId"          text="ID"          prefWidth="60.0"/>
                        <TableColumn fx:id="colTitre"        text="Titre"       prefWidth="180.0"/>
                        <TableColumn fx:id="colDescription"  text="Description" prefWidth="220.0"/>
                        <TableColumn fx:id="colDateDebut"    text="Date début"  prefWidth="130.0"/>
                        <TableColumn fx:id="colDateFin"      text="Date fin"    prefWidth="130.0"/>
                        <TableColumn fx:id="colPlaces"       text="Nb places"   prefWidth="110.0"/>
                    </columns>
                </TableView>
            </children>
        </AnchorPane>

        <!-- NAVIGATION BAS -->
        <Button layoutX="30.0" layoutY="674.0" text="➜  Gérer les Hackathons"
                prefWidth="200.0" prefHeight="36.0" onAction="#allerAcaton"
                style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
            <font><Font name="Arial Bold" size="12.0"/></font>
        </Button>

    </children>
</AnchorPane>
