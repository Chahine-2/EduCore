<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.GestionReservationMaterielController"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <Label text="Gestion des Reservations Materiels"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>

    <GridPane hgap="10" vgap="5">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <Label text="Materiel :" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1">
            <ComboBox fx:id="cbMateriel" prefWidth="250"
                      style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errMateriel" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <Label text="Motif :" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1">
            <TextField fx:id="tfMotif" prefWidth="250"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errMotif" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <Label text="Date debut :" GridPane.rowIndex="2" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1">
            <TextField fx:id="tfDateDebut" prefWidth="250"
                       promptText="yyyy-MM-ddTHH:mm  ex: 2026-05-10T09:00"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errDateDebut" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <Label text="Date fin :" GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1">
            <TextField fx:id="tfDateFin" prefWidth="250"
                       promptText="yyyy-MM-ddTHH:mm  ex: 2026-05-10T11:00"
                       style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errDateFin" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

        <Label text="Statut :" GridPane.rowIndex="4" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-text-fill: #202124;"/>
        <VBox GridPane.rowIndex="4" GridPane.columnIndex="1">
            <ComboBox fx:id="cbStatut" prefWidth="250"
                      style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
            <Label fx:id="errStatut" text=""
                   style="-fx-text-fill: #d93025; -fx-font-size: 11px;"/>
        </VBox>

    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter" onAction="#ajouterReservation"
                style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Modifier" onAction="#modifierReservation"
                style="-fx-background-color: #34a853; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Supprimer" onAction="#supprimerReservation"
                style="-fx-background-color: #d93025; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
        <Button text="Actualiser" onAction="#afficherReservations"
                style="-fx-background-color: #9334e6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tvReservations" prefHeight="350" prefWidth="800">
        <columns>
            <TableColumn fx:id="colMateriel"  text="Materiel"   prefWidth="150"/>
            <TableColumn fx:id="colMotif"     text="Motif"      prefWidth="150"/>
            <TableColumn fx:id="colDateDebut" text="Date debut" prefWidth="160"/>
            <TableColumn fx:id="colDateFin"   text="Date fin"   prefWidth="160"/>
            <TableColumn fx:id="colStatut"    text="Statut"     prefWidth="120"/>
        </columns>
    </TableView>

</VBox>