<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MenuPrincipalController"
      style="-fx-padding: 40; -fx-background-color: #2c3e50;">

    <Label text="🎓 Centre Éducatif"
           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label text="Système de Gestion des Matériels"
           style="-fx-font-size: 16px; -fx-text-fill: #bdc3c7;"/>

    <Button text="📦 Gestion des Matériels"
            onAction="#ouvrirMateriel"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 250; -fx-pref-height: 45;"/>

    <Button text="📅 Gestion des Réservations"
            onAction="#ouvrirReservation"
            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 250; -fx-pref-height: 45;"/>

    <Button text="📊 Statistiques"
            onAction="#ouvrirStatistiques"
            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 250; -fx-pref-height: 45;"/>

    <Button text="❌ Quitter"
            onAction="#quitter"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 250; -fx-pref-height: 45;"/>

</VBox>